{%- comment -%}
  tabblie-logo.liquid
  CSS-styled wordmark — "tabblie" in Fraunces serif, Tabblie Orange.
  Inherits the loaded Fraunces font correctly (no SVG font-loading race).
  Fills the header logo container width naturally.

  Parameters:
    color_scheme: 'light' (default) — orange — for light/cream/white backgrounds
                  'dark'            — white  — for dark/orange/footer backgrounds
    class:        extra CSS classes
{%- endcomment -%}

{%- assign logo_color_scheme = color_scheme | default: 'light' -%}

<span class="tabblie-wordmark tabblie-wordmark--{{ logo_color_scheme }}{% if class != blank %} {{ class }}{% endif %}" aria-label="Tabblie">Tabblie</span>
