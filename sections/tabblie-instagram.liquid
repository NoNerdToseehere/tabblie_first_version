        { "type": "post", "settings": { "likes": "156", "comments": "7" } },
        { "type": "post", "settings": { "likes": "278", "comments": "14" } },
        { "type": "post", "settings": { "likes": "198", "comments": "11" } },
        { "type": "post", "settings": { "likes": "245", "comments": "16" } },
        { "type": "post", "settings": { "likes": "167", "comments": "6" } },
        { "type": "post", "settings": { "likes": "289", "comments": "13" } }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
