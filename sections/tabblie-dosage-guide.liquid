{%- comment -%}
  tabblie-dosage-guide.liquid
  Visual usage/dosage guide with SVG illustrations.
  "Hoeveel moet je gebruiken?" — 3 columns with icons + descriptions.
{%- endcomment -%}

<style>
  .tdg {
    background: {{ section.settings.bg_color | default: '#FDF6EE' }};
    padding: clamp(48px, 6vw, 80px) clamp(16px, 3vw, 40px);
  }

  .tdg__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .tdg__header {
    text-align: center;
    margin-bottom: clamp(32px, 4vw, 56px);
  }

  .tdg__eyebrow {
    font-family: var(--text-font-family);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #E8622A;
    margin: 0 0 10px;
  }

  .tdg__heading {
    font-family: var(--heading-font-family);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 600;
    color: #1F1209;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  /* Cards grid */
  .tdg__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 2vw, 28px);
  }

  .tdg__card {
    background: #ffffff;
    border-radius: 16px;
    padding: clamp(24px, 3vw, 36px) clamp(20px, 2.5vw, 28px);
    text-align: center;
    box-shadow: 0 2px 16px rgba(31, 18, 9, 0.06);
  }

  .tdg__icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(232, 98, 42, 0.08);
  }

  .tdg__icon svg {
    width: 40px;
    height: 40px;
    color: #E8622A;
  }

  .tdg__amount {
    font-family: var(--heading-font-family);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 700;
    color: #E8622A;
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0 0 8px;
  }

  .tdg__label {
    font-family: var(--heading-font-family);
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    font-weight: 600;
    color: #1F1209;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0 0 10px;
  }

  .tdg__desc {
    font-family: var(--text-font-family);
    font-size: 14px;
    color: rgba(31, 18, 9, 0.65);
    line-height: 1.6;
    margin: 0;
  }

  /* Mobile — stack */
  @media (max-width: 749px) {
    .tdg__grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .tdg__card {
      display: grid;
      grid-template-columns: 68px 1fr;
      gap: 16px;
      text-align: left;
      padding: 18px;
    }

    .tdg__icon {
      width: 56px;
      height: 56px;
      margin: 0;
      grid-row: 1 / 3;
    }

    .tdg__icon svg { width: 28px; height: 28px; }

    .tdg__card-text {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .tdg__amount { font-size: 1.3rem; }
  }
</style>

<section class="tdg" id="tdg-{{ section.id }}">
  <div class="tdg__inner">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="tdg__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="tdg__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="tdg__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="tdg__grid">
      {%- for block in section.blocks -%}
        <div class="tdg__card" {{ block.shopify_attributes }}>
          <div class="tdg__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              {%- case block.settings.icon -%}
                {%- when 'strip-1' -%}
                  <rect x="8" y="3" width="8" height="18" rx="2"/><line x1="10" y1="8" x2="14" y2="8"/><line x1="10" y1="12" x2="14" y2="12"/>
                {%- when 'strip-half' -%}
                  <rect x="8" y="3" width="8" height="18" rx="2"/><line x1="8" y1="12" x2="16" y2="12" stroke-dasharray="2 2"/>
                {%- when 'strip-extra' -%}
                  <rect x="5" y="3" width="8" height="18" rx="2"/><rect x="11" y="3" width="8" height="18" rx="2" opacity="0.5"/>
                {%- when 'machine' -%}
                  <circle cx="12" cy="14" r="5"/><circle cx="12" cy="14" r="2" opacity="0.5"/><rect x="4" y="2" width="16" height="19" rx="3" fill="none"/><line x1="4" y1="8" x2="20" y2="8"/><circle cx="16" cy="5" r="1"/>
                {%- when 'drop' -%}
                  <path d="M12 2 C12 2 5 11 5 15 a 7 7 0 0 0 14 0 c 0-4-7-13-7-13z"/>
                {%- else -%}
                  <rect x="8" y="3" width="8" height="18" rx="2"/><line x1="10" y1="8" x2="14" y2="8"/>
              {%- endcase -%}
            </svg>
          </div>
          <div class="tdg__card-text">
            {%- if block.settings.amount != blank -%}
              <p class="tdg__amount">{{ block.settings.amount }}</p>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <p class="tdg__label">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="tdg__desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Dosage Guide",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FDF6EE" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "DOSERING" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Hoeveel moet je gebruiken?" }
  ],
  "blocks": [
    {
      "type": "dose",
      "name": "Dosage card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "strip-1",
          "options": [
            { "value": "strip-1", "label": "1 strip" },
            { "value": "strip-half", "label": "Half strip" },
            { "value": "strip-extra", "label": "Extra strip" },
            { "value": "machine", "label": "Machine" },
            { "value": "drop", "label": "Water drop" }
          ]
        },
        { "type": "text", "id": "amount", "label": "Amount (big text)", "default": "1 strip" },
        { "type": "text", "id": "title", "label": "Title", "default": "Normale was" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Eén strip per wasbeurt. Gooi in de trommel vóór het wasgoed, werkt op alle temperaturen." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dosage Guide",
      "blocks": [
        {
          "type": "dose",
          "settings": {
            "icon": "strip-1",
            "amount": "1 strip",
            "title": "Normale was",
            "description": "Eén strip per wasbeurt. Gooi in de trommel vóór het wasgoed. Werkt op alle temperaturen."
          }
        },
        {
          "type": "dose",
          "settings": {
            "icon": "strip-half",
            "amount": "½ strip",
            "title": "Kleine was of opfrisbeurt",
            "description": "Half lading of licht vervuilde kleding? Een halve strip is genoeg."
          }
        },
        {
          "type": "dose",
          "settings": {
            "icon": "strip-extra",
            "amount": "1½ strip",
            "title": "Extra vuile was",
            "description": "Sportkleding, werkkleding of hardnekkige vlekken? Gebruik anderhalve strip voor maximale reiniging."
          }
        }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
