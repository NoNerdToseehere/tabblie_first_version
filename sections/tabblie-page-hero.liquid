{%- comment -%}
  tabblie-page-hero.liquid
  Full-width hero for interior pages. Big heading with accent, subtext, optional CTA.
{%- endcomment -%}

<style>
  .tabblie-phero {
    background-color: {{ section.settings.bg_color }};
    padding: clamp(40px, 5vw, 72px) clamp(16px, 3vw, 40px);
    text-align: center;
  }

  .tabblie-phero__inner {
    max-width: 780px;
    margin: 0 auto;
  }

  .tabblie-phero__eyebrow {
    font-family: var(--text-font-family);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #E8622A;
    margin-bottom: 18px;
  }

  .tabblie-phero__title {
    font-family: var(--font-heading-family);
    font-size: clamp(2.8rem, 6vw, 5.2rem);
    font-weight: var(--font-heading-weight);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #1F1209;
    margin: 0 0 24px;
  }

  .tabblie-phero__accent {
    color: #E8622A;
    font-style: italic;
    font-weight: 400;
  }

  .tabblie-phero__sub {
    font-family: var(--text-font-family);
    font-size: clamp(15px, 1.8vw, 18px);
    color: rgba(31, 18, 9, 0.6);
    line-height: 1.7;
    margin: 0 auto 32px;
    max-width: 600px;
  }

  .tabblie-phero__cta {
    display: inline-block;
    background: #E8622A;
    color: #ffffff;
    font-family: var(--text-font-family);
    font-size: 14px;
    font-weight: 600;
    padding: 12px 32px;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .tabblie-phero__cta:hover {
    background: #d4531d;
    color: #ffffff;
  }
</style>

<section class="tabblie-phero">
  <div class="tabblie-phero__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="tabblie-phero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 class="tabblie-phero__title">
      {{- section.settings.heading -}}
      {%- if section.settings.heading_accent != blank -%}
        <span class="tabblie-phero__accent"> {{ section.settings.heading_accent }}</span>
      {%- endif -%}
    </h1>
    {%- if section.settings.subtext != blank -%}
      <p class="tabblie-phero__sub">{{ section.settings.subtext }}</p>
    {%- endif -%}
    {%- if section.settings.button_text != blank -%}
      <a class="tabblie-phero__cta" href="{{ section.settings.button_url | default: '#' }}">
        {{ section.settings.button_text }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Page Hero",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#FDF6EE" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic orange)" },
    { "type": "textarea", "id": "subtext", "label": "Subtext" },
    { "type": "text", "id": "button_text", "label": "Button text" },
    { "type": "url", "id": "button_url", "label": "Button link" }
  ],
  "presets": [{ "name": "Page Hero" }]
}
{% endschema %}
