{%- comment -%}
  tabblie-blog-list.liquid
  Minimal blog listing inspired by thelekkercompany.com:
  clean header, grid of square-image cards with titles below.
{%- endcomment -%}

<style>
  .tbl-wrap {
    background: #FDF6EE;
    padding: clamp(48px, 6vw, 80px) clamp(16px, 3vw, 40px);
  }

  .tbl-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Header */
  .tbl-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto clamp(36px, 5vw, 64px);
  }

  .tbl-eyebrow {
    font-family: var(--text-font-family);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #E8622A;
    margin: 0 0 12px;
  }

  .tbl-title {
    font-family: var(--heading-font-family);
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    font-weight: 600;
    color: #1F1209;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 14px;
  }

  .tbl-subtitle {
    font-family: var(--text-font-family);
    font-size: clamp(0.95rem, 1.1vw, 1.1rem);
    color: rgba(31, 18, 9, 0.65);
    line-height: 1.6;
    margin: 0;
  }

  /* Grid */
  .tbl-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 3vw, 48px) clamp(20px, 2.5vw, 36px);
  }

  @media (max-width: 1024px) {
    .tbl-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .tbl-grid { grid-template-columns: 1fr; gap: 32px; }
  }

  /* Card */
  .tbl-card {
    display: block;
    text-decoration: none;
    color: #1F1209;
    transition: transform 0.3s ease;
  }

  .tbl-card:hover {
    color: #1F1209;
    transform: translateY(-3px);
  }

  .tbl-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 4px;
    background: #F0E6DA;
    margin-bottom: 16px;
  }

  .tbl-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .tbl-card:hover .tbl-card__media img {
    transform: scale(1.04);
  }

  .tbl-card__placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(232,98,42,0.15) 0%, rgba(91,184,160,0.15) 50%, rgba(245,200,66,0.15) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--heading-font-family);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(31, 18, 9, 0.4);
  }

  .tbl-card__tag {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(255, 255, 255, 0.95);
    color: #E8622A;
    font-family: var(--text-font-family);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 100px;
  }

  .tbl-card__meta {
    font-family: var(--text-font-family);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(31, 18, 9, 0.5);
    margin: 0 0 6px;
  }

  .tbl-card__title {
    font-family: var(--heading-font-family);
    font-size: clamp(1.1rem, 1.4vw, 1.35rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.25;
    margin: 0;
    transition: color 0.2s ease;
  }

  .tbl-card:hover .tbl-card__title {
    color: #E8622A;
  }

  /* Empty state */
  .tbl-empty {
    text-align: center;
    padding: clamp(40px, 6vw, 80px) 20px;
    background: #ffffff;
    border-radius: 16px;
    max-width: 560px;
    margin: 0 auto;
  }

  .tbl-empty__title {
    font-family: var(--heading-font-family);
    font-size: 1.4rem;
    font-weight: 600;
    color: #1F1209;
    margin: 0 0 10px;
  }

  .tbl-empty__text {
    font-family: var(--text-font-family);
    font-size: 15px;
    color: rgba(31, 18, 9, 0.65);
    line-height: 1.6;
    margin: 0;
  }

  /* Pagination */
  .tbl-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: clamp(36px, 5vw, 64px);
  }

  .tbl-pagination a,
  .tbl-pagination span {
    font-family: var(--text-font-family);
    font-size: 14px;
    font-weight: 600;
    color: rgba(31, 18, 9, 0.5);
    padding: 8px 14px;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .tbl-pagination a:hover { color: #E8622A; }
  .tbl-pagination .tbl-pagination--current {
    background: #E8622A;
    color: #ffffff;
  }
</style>

<section class="tbl-wrap" id="tabblie-blog-{{ section.id }}">
  <div class="tbl-inner">
    <header class="tbl-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="tbl-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="tbl-title">{{ blog.title | default: section.settings.title }}</h1>
      {%- if section.settings.subtitle != blank -%}
        <p class="tbl-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </header>

    {%- paginate blog.articles by section.settings.per_page -%}
      {%- if blog.articles.size > 0 -%}
        <div class="tbl-grid">
          {%- for article in blog.articles -%}
            <a class="tbl-card" href="{{ article.url }}">
              <div class="tbl-card__media">
                {%- if article.image -%}
                  <img src="{{ article.image | image_url: width: 800 }}"
                       srcset="{{ article.image | image_url: width: 400 }} 400w,
                               {{ article.image | image_url: width: 600 }} 600w,
                               {{ article.image | image_url: width: 800 }} 800w"
                       sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                       alt="{{ article.image.alt | default: article.title | escape }}"
                       width="800" height="800" loading="lazy">
                {%- else -%}
                  <div class="tbl-card__placeholder">Tabblie</div>
                {%- endif -%}
                {%- if article.tags.size > 0 -%}
                  <span class="tbl-card__tag">{{ article.tags | first }}</span>
                {%- endif -%}
              </div>
              <p class="tbl-card__meta">{{ article.published_at | date: '%d %b %Y' }}</p>
              <h2 class="tbl-card__title">{{ article.title }}</h2>
            </a>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="tbl-pagination" role="navigation" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" aria-label="Previous">←</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}
                <span class="tbl-pagination--current">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" aria-label="Next">→</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="tbl-empty">
          <p class="tbl-empty__title">Binnenkort</p>
          <p class="tbl-empty__text">We werken aan de eerste artikelen. Check snel terug voor tips over schoonmaken zonder plasticafval, achtergrondverhalen en nieuws over onze stichting.</p>
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Tabblie Blog List",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "INSPIRATIE" },
    { "type": "text", "id": "title", "label": "Fallback title (used if blog has no title)", "default": "Verhalen van Tabblie" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Tips, achtergronden en verhalen over schoonmaken zonder plasticafval." },
    { "type": "range", "id": "per_page", "label": "Articles per page", "min": 6, "max": 30, "step": 3, "default": 12 }
  ],
  "presets": [{ "name": "Tabblie Blog List" }]
}
{% endschema %}
