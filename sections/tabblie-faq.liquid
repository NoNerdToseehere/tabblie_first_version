{%- comment -%}
  tabblie-faq.liquid
  FAQ accordion using native HTML <details>/<summary> — zero JS.
  Brand: orange eyebrow/icon, dark earth text, white background.
{%- endcomment -%}

<style>
  .tabblie-faq {
    background-color: #FFFFFF;
    padding: clamp(56px, 7vw, 96px) clamp(16px, 3vw, 40px);
  }

  .tabblie-faq__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .tabblie-faq__header {
    text-align: center;
    margin-bottom: clamp(32px, 4vw, 56px);
  }

  .tabblie-faq__eyebrow {
    font-family: var(--font-heading-family);
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    font-weight: 600;
    color: #1F1209;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .tabblie-faq__title {
    font-family: var(--text-font-family);
    font-size: 15px;
    font-weight: 400;
    color: rgba(31, 18, 9, 0.5);
    line-height: 1.5;
    margin: 0;
  }

  /* FAQ list */
  .tabblie-faq__list {
    max-width: 720px;
    margin: 0 auto;
  }

  /* Single item */
  .tabblie-faq__item {
    border-bottom: 1px solid rgba(31, 18, 9, 0.1);
  }

  .tabblie-faq__item:first-child {
    border-top: 1px solid rgba(31, 18, 9, 0.1);
  }

  .tabblie-faq__item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 0;
    cursor: pointer;
    list-style: none;
    font-family: var(--heading-font-family);
    font-size: clamp(1.05rem, 1.2vw, 1.2rem);
    font-weight: 600;
    color: #1F1209;
    line-height: 1.35;
    user-select: none;
    -webkit-user-select: none;
  }

  /* Remove default marker */
  .tabblie-faq__item summary::-webkit-details-marker {
    display: none;
  }

  .tabblie-faq__item summary::marker {
    content: '';
  }

  /* Toggle icon */
  .tabblie-faq__icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tabblie-faq__icon::before,
  .tabblie-faq__icon::after {
    content: '';
    position: absolute;
    background-color: #E8622A;
    border-radius: 1px;
    transition: transform 0.25s ease;
  }

  /* Horizontal bar */
  .tabblie-faq__icon::before {
    width: 16px;
    height: 2px;
  }

  /* Vertical bar (forms the +) */
  .tabblie-faq__icon::after {
    width: 2px;
    height: 16px;
  }

  /* When open: rotate vertical bar to form - */
  .tabblie-faq__item[open] .tabblie-faq__icon::after {
    transform: rotate(90deg);
  }

  /* Answer */
  .tabblie-faq__answer {
    padding: 0 0 24px;
    font-family: var(--text-font-family);
    font-size: clamp(0.95rem, 1vw, 1.05rem);
    color: rgba(31, 18, 9, 0.7);
    line-height: 1.7;
    max-width: 640px;
  }

  .tabblie-faq__answer p {
    margin: 0;
  }

  /* Section icon */
  .tabblie-faq__section-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #E8622A;
    margin: 0 auto 12px;
  }

  .tabblie-faq__section-icon svg {
    width: 40px;
    height: 40px;
  }

  /* Mobile */
  @media (max-width: 749px) {
    .tabblie-faq {
      padding: 56px 20px;
    }

    .tabblie-faq__item summary {
      padding: 18px 0;
      font-size: 1.05rem;
    }

    .tabblie-faq__answer {
      padding-bottom: 20px;
      font-size: 0.95rem;
    }
  }
</style>

<section class="tabblie-faq" id="tabblie-faq-{{ section.id }}">
  <div class="tabblie-faq__inner">

    <div class="tabblie-faq__header">
      {%- if section.settings.icon != 'none' and section.settings.icon != blank -%}
        <div class="tabblie-faq__section-icon">
          {%- case section.settings.icon -%}
            {%- when 'product' -%}
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12"/></svg>
            {%- when 'shipping' -%}
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 18H3a1 1 0 01-1-1V7a1 1 0 011-1h10v11m0-11h3l4 5v6a1 1 0 01-1 1h-1"/><circle cx="7.5" cy="18.5" r="1.5"/><circle cx="17.5" cy="18.5" r="1.5"/></svg>
            {%- when 'return' -%}
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
            {%- when 'leaf' -%}
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 22c1-6 5.5-12 15-13"/><path d="M17 9c-2 0-6 1-8.5 5.5"/><path d="M22 2L17 9"/></svg>
            {%- when 'question' -%}
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 8.5a3 3 0 016 0c0 2-3 2.5-3 4.5"/><line x1="12" y1="17.5" x2="12" y2="17.5"/></svg>
            {%- when 'globe' -%}
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            {%- when 'turtle' -%}
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 10c-3.3 0-6 2.2-6 5s2.7 5 6 5 6-2.2 6-5-2.7-5-6-5z"/><path d="M12 10V7"/><circle cx="12" cy="5.5" r="1.5"/><path d="M7 13l-3 2"/><path d="M17 13l3 2"/><path d="M8 18l-2 2"/><path d="M16 18l2 2"/><path d="M9 13c0 0 1.5-1 3-1s3 1 3 1"/></svg>
          {%- endcase -%}
        </div>
      {%- endif -%}
      {%- if section.settings.eyebrow != blank -%}
        <p class="tabblie-faq__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="tabblie-faq__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="tabblie-faq__list">
        {%- for block in section.blocks -%}
          <details class="tabblie-faq__item" {{ block.shopify_attributes }}>
            <summary>
              <span>{{ block.settings.question }}</span>
              <span class="tabblie-faq__icon" aria-hidden="true"></span>
            </summary>
            <div class="tabblie-faq__answer">
              <p>{{ block.settings.answer }}</p>
            </div>
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "icon",
      "label": "Section icon",
      "default": "question",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "product", "label": "Product (box)" },
        { "value": "shipping", "label": "Shipping (truck)" },
        { "value": "return", "label": "Return (shield)" },
        { "value": "leaf", "label": "Sustainability (leaf)" },
        { "value": "question", "label": "Question mark" },
        { "value": "globe", "label": "Globe (world)" },
        { "value": "turtle", "label": "Turtle (vegan/animal)" }
      ]
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "VEELGESTELDE VRAGEN"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Alles wat je wilt weten"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "Zijn jullie strips echt plasticvrij?",
            "answer": "Ja! Onze strips worden verpakt in recyclebaar papier. Geen plastic fles, geen plastic verpakking, geen microplastics in de formule."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Werken de strips net zo goed als vloeibaar wasmiddel?",
            "answer": "Absoluut. Onze strips bevatten dezelfde werkzame stoffen als premium wasmiddelen, maar dan in geconcentreerde vorm. Ze lossen volledig op in warm \u00e9n koud water."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Zijn de ingredi\u00ebnten veilig voor gevoelige huid?",
            "answer": "Ja. Onze formule is vrij van parabenen, fosfaten, kleurstoffen en kunstmatige geurstoffen. Dermatologisch getest en geschikt voor de hele familie."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Hoe zit het met de verzending?",
            "answer": "We verzenden gratis naar Nederland en Belgi\u00eb. Omdat onze strips zo compact en licht zijn, is de CO\u2082-uitstoot van verzending tot 90% lager dan bij traditionele schoonmaakmiddelen."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Is tabblie vegan en dierproefvrij?",
            "answer": "100%. Geen dierlijke ingredi\u00ebnten, geen dierproeven. Ooit."
          }
        }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
