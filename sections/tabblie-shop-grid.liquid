{%- comment -%}
  tabblie-shop-grid.liquid
  2x2 grid of large product category cards with images.
{%- endcomment -%}

<style>
  .tabblie-shop {
    background-color: #FDF6EE;
    padding: clamp(40px, 5vw, 72px) clamp(16px, 3vw, 40px);
  }

  .tabblie-shop__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .tabblie-shop__header {
    text-align: center;
    margin-bottom: clamp(36px, 5vw, 56px);
  }

  .tabblie-shop__title {
    font-family: var(--font-heading-family);
    font-size: clamp(2.4rem, 4vw, 4rem);
    font-weight: var(--font-heading-weight);
    color: #1F1209;
    line-height: 1.1;
    margin: 0;
  }

  .tabblie-shop__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(16px, 2vw, 24px);
  }

  .tabblie-shop__card {
    background: #ffffff;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    display: flex;
    flex-direction: column;
  }

  .tabblie-shop__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(31, 18, 9, 0.08);
  }

  .tabblie-shop__card-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: var(--card-bg, #f5f5f5);
  }

  .tabblie-shop__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .tabblie-shop__card:hover .tabblie-shop__card-img img {
    transform: scale(1.03);
  }

  .tabblie-shop__card-body {
    padding: clamp(20px, 2.5vw, 28px);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .tabblie-shop__card-stars {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
  }

  .tabblie-shop__card-stars img {
    height: 20px;
  }

  .tabblie-shop__card-stars span {
    font-family: var(--text-font-family);
    font-size: 12px;
    color: rgba(31, 18, 9, 0.5);
  }

  .tabblie-shop__card-name {
    font-family: var(--font-heading-family);
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 500;
    color: #1F1209;
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .tabblie-shop__card-desc {
    font-family: var(--text-font-family);
    font-size: 14px;
    color: rgba(31, 18, 9, 0.55);
    line-height: 1.6;
    margin: 0 0 16px;
    flex: 1;
  }

  .tabblie-shop__card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .tabblie-shop__card-price {
    font-family: var(--text-font-family);
    font-size: 18px;
    font-weight: 700;
    color: #E8622A;
  }

  .tabblie-shop__card-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #E8622A;
    color: #ffffff;
    flex-shrink: 0;
    transition: background 0.2s ease;
  }

  .tabblie-shop__card-btn:hover {
    background: #d4531d;
  }

  .tabblie-shop__card-placeholder {
    width: 100%;
    height: 100%;
    background: var(--card-bg, rgba(232, 98, 42, 0.1));
  }

  @media (max-width: 749px) {
    .tabblie-shop__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .tabblie-shop__card-img {
      aspect-ratio: 16 / 10;
    }
  }
</style>

<section class="tabblie-shop">
  <div class="tabblie-shop__inner">
    {%- if section.settings.title != blank -%}
      <div class="tabblie-shop__header">
        <h1 class="tabblie-shop__title">{{ section.settings.title }}</h1>
      </div>
    {%- endif -%}

    <div class="tabblie-shop__grid">
      {%- for block in section.blocks -%}
        {%- assign product = all_products[block.settings.product] -%}
        {%- assign card_url = block.settings.url | default: product.url | default: '#' -%}
        {%- assign card_name = block.settings.name | default: product.title | default: 'Product' -%}
        {%- assign card_desc = block.settings.description -%}
        {%- assign card_price = product.price | money -%}

        <a class="tabblie-shop__card" href="{{ card_url }}" style="--card-bg: {{ block.settings.bg_color }}" {{ block.shopify_attributes }}>
          <div class="tabblie-shop__card-img">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ card_name | escape }}"
                width="800"
                height="600"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              >
            {%- elsif product.featured_image != blank -%}
              <img
                src="{{ product.featured_image | image_url: width: 800 }}"
                alt="{{ card_name | escape }}"
                width="800"
                height="600"
                loading="lazy"
              >
            {%- else -%}
              {%- assign name_lower = card_name | downcase -%}
              {%- if name_lower contains 'wasstrip' or name_lower contains 'laundry' -%}
                <img src="{{ 'tabblie-wasstrips.png' | asset_url }}" alt="{{ card_name | escape }}" width="800" height="600" loading="lazy">
              {%- elsif name_lower contains 'vaatwas' or name_lower contains 'dishwash' -%}
                <img src="{{ 'tabblie-vaatwasstrips.png' | asset_url }}" alt="{{ card_name | escape }}" width="800" height="600" loading="lazy">
              {%- elsif name_lower contains 'toilet' -%}
                <img src="{{ 'tabblie-toiletstrips.png' | asset_url }}" alt="{{ card_name | escape }}" width="800" height="600" loading="lazy">
              {%- elsif name_lower contains 'alles' or name_lower contains 'all-purpose' -%}
                <img src="{{ 'tabblie-allesreiniger.png' | asset_url }}" alt="{{ card_name | escape }}" width="800" height="600" loading="lazy">
              {%- else -%}
                <div class="tabblie-shop__card-placeholder"></div>
              {%- endif -%}
            {%- endif -%}
          </div>

          <div class="tabblie-shop__card-body">
            <div class="tabblie-shop__card-stars">
              <img src="{{ 'stars-4.7.svg' | asset_url }}" alt="4.7 sterren" style="height:18px">
            </div>

            <h2 class="tabblie-shop__card-name">{{ card_name }}</h2>

            {%- if card_desc != blank -%}
              <p class="tabblie-shop__card-desc">{{ card_desc }}</p>
            {%- endif -%}

            <div class="tabblie-shop__card-footer">
              {%- if product -%}
                <span class="tabblie-shop__card-price">{{ card_price }}</span>
              {%- endif -%}
              <span class="tabblie-shop__card-btn" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop Grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Onze producten"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Display name (override)",
          "info": "Leave blank to use product title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link (override)",
          "info": "Leave blank to use product URL"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image (override)",
          "info": "Leave blank to use product image"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Image background color",
          "default": "#f5f5f5"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop Grid"
    }
  ],
  "max_blocks": 8
}
{% endschema %}
