{%- comment -%}
  tabblie-trust-row.liquid
  Compact horizontal trust badge row with icons.
  Shared across Earth Breeze + Mother's Earth product templates.
{%- endcomment -%}

<style>
  .ttr {
    background: {{ section.settings.bg_color | default: '#FDF6EE' }};
    padding: clamp(24px, 3vw, 40px) clamp(16px, 3vw, 40px);
  }

  .ttr__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: clamp(12px, 2vw, 32px);
    flex-wrap: wrap;
  }

  .ttr__item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    background: #ffffff;
    border-radius: 100px;
    border: 1px solid rgba(31, 18, 9, 0.08);
    flex-shrink: 0;
  }

  .ttr__icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    color: #E8622A;
  }

  .ttr__text {
    font-family: var(--text-font-family);
    font-size: 13px;
    font-weight: 600;
    color: #1F1209;
    white-space: nowrap;
  }

  @media (max-width: 749px) {
    .ttr__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .ttr__item {
      padding: 10px 14px;
      border-radius: 12px;
      justify-content: center;
    }

    .ttr__icon { width: 18px; height: 18px; }
    .ttr__text { font-size: 12px; }
  }
</style>

<section class="ttr" id="ttr-{{ section.id }}">
  <div class="ttr__inner">
    {%- for block in section.blocks -%}
      <div class="ttr__item" {{ block.shopify_attributes }}>
        <svg class="ttr__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          {%- case block.settings.icon -%}
            {%- when 'lock' -%}
              <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
            {%- when 'truck' -%}
              <path d="M5 18H3a1 1 0 01-1-1V7a1 1 0 011-1h10v11m0-11h3l4 5v6a1 1 0 01-1 1h-1"/><circle cx="7.5" cy="18.5" r="1.5"/><circle cx="17.5" cy="18.5" r="1.5"/>
            {%- when 'clock' -%}
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            {%- when 'shield' -%}
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>
            {%- when 'star' -%}
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            {%- when 'leaf' -%}
              <path d="M2 22c1-6 5.5-12 15-13"/><path d="M17 9c-2 0-6 1-8.5 5.5"/><path d="M22 2L17 9"/>
            {%- when 'heart' -%}
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z"/>
            {%- when 'check' -%}
              <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/>
            {%- when 'refresh' -%}
              <polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/>
          {%- endcase -%}
        </svg>
        <span class="ttr__text">{{ block.settings.text }}</span>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust Badge Row",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#FDF6EE" }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "shield",
          "options": [
            { "value": "lock", "label": "Lock (secure)" },
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "clock", "label": "Clock (fast)" },
            { "value": "shield", "label": "Shield (guarantee)" },
            { "value": "star", "label": "Star (quality)" },
            { "value": "leaf", "label": "Leaf (eco)" },
            { "value": "heart", "label": "Heart (vegan)" },
            { "value": "check", "label": "Checkmark (verified)" },
            { "value": "refresh", "label": "Refresh (returns)" }
          ]
        },
        { "type": "text", "id": "text", "label": "Text", "default": "Trust badge" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badge Row",
      "blocks": [
        { "type": "badge", "settings": { "icon": "lock", "text": "Veilig betalen" } },
        { "type": "badge", "settings": { "icon": "truck", "text": "Gratis verzending NL & BE" } },
        { "type": "badge", "settings": { "icon": "clock", "text": "1-2 dagen geleverd" } },
        { "type": "badge", "settings": { "icon": "shield", "text": "30 dagen garantie" } }
      ]
    }
  ],
  "max_blocks": 8
}
{% endschema %}