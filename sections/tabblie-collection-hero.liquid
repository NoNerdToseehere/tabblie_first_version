{%- comment -%}
  tabblie-collection-hero.liquid
  MEDVi-style hero with 4 collection category cards + marquee strip.
  Brand: Tabblie — dark earth background, Fraunces heading, orange accent.
{%- endcomment -%}

<style>
  .tabblie-chero {
    background: linear-gradient(160deg, #E1ECFA 0%, #C8D9F5 40%, #D5E3F8 70%, #E8EFF9 100%);
    position: relative;
    overflow: hidden;
  }

  .tabblie-chero::before {
    content: 'tabblie';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -55%);
    font-family: var(--font-heading-family);
    font-size: clamp(12rem, 20vw, 22rem);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.05em;
    white-space: nowrap;
    pointer-events: none;
    z-index: 0;
  }

  /* Floating decorative leaves */
  .tabblie-chero__leaf {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .tabblie-chero__leaf--1 {
    top: 8%;
    left: -40px;
    width: 180px;
    height: 180px;
    color: #5BB8A0;
    opacity: 0.25;
    transform: rotate(-20deg);
  }

  .tabblie-chero__leaf--2 {
    top: 12%;
    right: -30px;
    width: 150px;
    height: 150px;
    color: #E8622A;
    opacity: 0.2;
    transform: rotate(130deg);
  }

  .tabblie-chero__leaf--3 {
    bottom: 30%;
    left: 8%;
    width: 80px;
    height: 80px;
    color: #F5C842;
    opacity: 0.3;
    transform: rotate(45deg);
  }

  .tabblie-chero__leaf--4 {
    top: 40%;
    right: 10%;
    width: 110px;
    height: 110px;
    color: #5BB8A0;
    opacity: 0.22;
    transform: rotate(-60deg);
  }

  @media (max-width: 749px) {
    .tabblie-chero__leaf--1,
    .tabblie-chero__leaf--2 {
      width: 110px;
      height: 110px;
    }
    .tabblie-chero__leaf--3,
    .tabblie-chero__leaf--4 {
      display: none;
    }
  }

  @media (max-width: 749px) {
    .tabblie-chero::before {
      top: 45.5%;
      font-size: 8rem;
    }
  }

  .tabblie-chero__inner {
    position: relative;
    z-index: 1;
  }

  .tabblie-chero__cards-wrap {
    position: relative;
    z-index: 1;
  }

  .tabblie-chero__marquee {
    position: relative;
    z-index: 1;
  }

  .tabblie-chero__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(40px, 5vw, 72px) clamp(16px, 3vw, 40px) clamp(36px, 4vw, 56px);
    text-align: center;
  }

  /* Badge */
  .tabblie-chero__badge {
    display: inline-block;
    font-family: var(--text-font-family);
    font-size: 14px;
    font-weight: 500;
    color: rgba(31, 18, 9, 0.65);
    letter-spacing: 0.04em;
    margin-bottom: 20px;
  }

  .tabblie-chero__badge strong {
    color: #1F1209;
    font-weight: 700;
  }

  /* Heading */
  .tabblie-chero__heading {
    font-family: var(--heading-font-family);
    font-size: clamp(2.8rem, 6vw, 5.6rem);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: #1F1209;
    margin: 0 auto 20px;
    max-width: 820px;
  }

  .tabblie-chero__accent {
    color: #E8622A;
    font-style: italic;
    font-weight: 400;
  }

  /* Subtext */
  .tabblie-chero__sub {
    font-family: var(--text-font-family);
    font-size: clamp(15px, 1.8vw, 18px);
    color: rgba(31, 18, 9, 0.6);
    line-height: 1.6;
    margin: 0 auto 52px;
    max-width: 520px;
  }

  /* ── Cards white panel ── */
  .tabblie-chero__cards-wrap {
    background-color: #ffffff;
    border-radius: 32px 32px 0 0;
    padding: clamp(28px, 3.5vw, 48px) clamp(20px, 3vw, 40px) clamp(36px, 4vw, 52px);
    width: 88%;          /* always ~6% blue visible on each side */
    max-width: 1100px;   /* cap on very wide screens */
    margin: -28px auto 0;
  }

  /* ── Cards grid ── */
  .tabblie-chero__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(8px, 1vw, 16px);
    align-items: end;
  }

  .tabblie-chero__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border-radius: 16px 16px 0 0;
    overflow: hidden;
    transition: transform 0.25s ease;
  }

  .tabblie-chero__card:hover {
    transform: translateY(-4px);
  }

  /* card image */
  .tabblie-chero__card-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 14px 14px 0 0;
  }

  .tabblie-chero__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .tabblie-chero__card:hover .tabblie-chero__card-img img {
    transform: scale(1.04);
  }

  /* placeholder when no image */
  .tabblie-chero__card-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--card-accent, #E8622A);
    opacity: 0.18;
  }

  /* card footer label */
  .tabblie-chero__card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 4px 0;
    gap: 6px;
  }

  .tabblie-chero__card-label {
    font-family: var(--text-font-family);
    font-size: 15px;
    font-weight: 600;
    color: #1F1209;
    text-align: left;
    line-height: 1.3;
  }

  .tabblie-chero__card-arrow {
    flex-shrink: 0;
    color: #E8622A;
    display: flex;
    align-items: center;
    transition: transform 0.2s ease;
  }

  .tabblie-chero__card:hover .tabblie-chero__card-arrow {
    transform: translateX(3px);
  }

  /* per-card accent colours */
  .tabblie-chero__card:nth-child(1) .tabblie-chero__card-img { background-color: rgba(232,98,42,0.15); }
  .tabblie-chero__card:nth-child(2) .tabblie-chero__card-img { background-color: rgba(245,200,66,0.15); }
  .tabblie-chero__card:nth-child(3) .tabblie-chero__card-img { background-color: rgba(91,184,160,0.15); }
  .tabblie-chero__card:nth-child(4) .tabblie-chero__card-img { background-color: rgba(242,160,160,0.15); }

  /* ── Marquee strip ── */
  .tabblie-chero__marquee {
    margin-top: 0;
    background-color: #f4633a;
    border-top: none;
    padding: 14px 0;
    overflow: hidden;
  }

  .tabblie-chero__marquee-track {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: tabblie-marquee 28s linear infinite;
  }

  .tabblie-chero__marquee:hover .tabblie-chero__marquee-track {
    animation-play-state: paused;
  }

  .tabblie-chero__marquee-item {
    font-family: var(--text-font-family);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #FFFFFF;
    padding: 0 28px;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }

  .tabblie-chero__marquee-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    opacity: 0.9;
  }

  .tabblie-chero__marquee-dot {
    color: rgba(255, 255, 255, 0.5);
    font-size: 18px;
    line-height: 1;
    flex-shrink: 0;
  }

  @keyframes tabblie-marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }

  /* ── MOBILE ── */
  @media (max-width: 749px) {
    /* Text area: no bottom padding — white wrap overlaps below */
    .tabblie-chero__inner {
      padding: 56px 24px 40px;
    }

    .tabblie-chero__badge {
      font-size: 13px;
      margin-bottom: 16px;
    }

    .tabblie-chero__heading {
      font-size: clamp(3rem, 11vw, 4rem);
      margin-bottom: 16px;
    }

    .tabblie-chero__sub {
      font-size: 16px;
      margin-bottom: 0;
    }

    /* White panel: full-width on mobile */
    .tabblie-chero__cards-wrap {
      width: 100%;
      max-width: 100%;
      margin: -24px 0 0;
      border-radius: 28px 28px 0 0;
      padding: 14px 14px 18px;
      background-color: #ffffff !important;
    }

    .tabblie-chero__cards {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    /* Remove gap so white panel connects directly to orange marquee */
    .tabblie-chero__marquee {
      margin-top: 0;
    }

    /* Each tab: white card, colored image area on left */
    .tabblie-chero__card {
      flex-direction: row;
      align-items: stretch;
      border-radius: 16px;
      background-color: #ffffff;
      padding: 0;
      border-bottom: none;
      box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06);
      overflow: hidden;
    }

    .tabblie-chero__card:hover {
      transform: none;
    }

    .tabblie-chero__card-img {
      width: 110px;
      min-height: 72px;
      flex-shrink: 0;
      aspect-ratio: auto;
      border-radius: 0;
      overflow: hidden;
    }

    .tabblie-chero__card:nth-child(1) .tabblie-chero__card-img { background-color: #FDEEE6; }
    .tabblie-chero__card:nth-child(2) .tabblie-chero__card-img { background-color: #FDF5DD; }
    .tabblie-chero__card:nth-child(3) .tabblie-chero__card-img { background-color: #E2F2ED; }
    .tabblie-chero__card:nth-child(4) .tabblie-chero__card-img { background-color: #FCE8E8; }

    .tabblie-chero__card-img img {
      object-fit: cover;
      width: 100%;
      height: 100%;
    }

    .tabblie-chero__card-foot {
      flex: 1;
      padding: 12px 16px;
      align-items: center;
    }

    .tabblie-chero__card-label {
      font-size: 15px;
      font-weight: 600;
      color: #1F1209;
    }

    .tabblie-chero__card-arrow {
      color: #1F1209;
    }
  }

  /* ── TABLET ── */
  @media (min-width: 750px) and (max-width: 1023px) {
    .tabblie-chero__cards-wrap {
      padding: 40px 24px 40px;
    }

    .tabblie-chero__cards {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }
</style>

<section class="tabblie-chero" id="tabblie-chero-{{ section.id }}">
  <svg class="tabblie-chero__leaf tabblie-chero__leaf--1" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <path d="M50 5 C 25 5, 10 30, 10 55 C 10 75, 25 90, 50 95 C 50 70, 35 50, 20 40 C 40 45, 55 60, 50 95 C 75 90, 90 75, 90 55 C 90 30, 75 5, 50 5 Z"/>
  </svg>
  <svg class="tabblie-chero__leaf tabblie-chero__leaf--2" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <path d="M50 5 C 25 5, 10 30, 10 55 C 10 75, 25 90, 50 95 C 50 70, 35 50, 20 40 C 40 45, 55 60, 50 95 C 75 90, 90 75, 90 55 C 90 30, 75 5, 50 5 Z"/>
  </svg>
  <svg class="tabblie-chero__leaf tabblie-chero__leaf--3" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <path d="M50 5 C 25 5, 10 30, 10 55 C 10 75, 25 90, 50 95 C 50 70, 35 50, 20 40 C 40 45, 55 60, 50 95 C 75 90, 90 75, 90 55 C 90 30, 75 5, 50 5 Z"/>
  </svg>
  <svg class="tabblie-chero__leaf tabblie-chero__leaf--4" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <path d="M50 5 C 25 5, 10 30, 10 55 C 10 75, 25 90, 50 95 C 50 70, 35 50, 20 40 C 40 45, 55 60, 50 95 C 75 90, 90 75, 90 55 C 90 30, 75 5, 50 5 Z"/>
  </svg>
  <div class="tabblie-chero__inner">

    {%- if section.settings.badge_text != blank -%}
      <p class="tabblie-chero__badge">{{ section.settings.badge_text }}</p>
    {%- endif -%}

    <h2 class="tabblie-chero__heading">
      {{- section.settings.heading -}}
      {%- if section.settings.heading_accent != blank -%}
        <em class="tabblie-chero__accent"> {{ section.settings.heading_accent }}</em>
      {%- endif -%}
    </h2>

    {%- if section.settings.subtext != blank -%}
      <p class="tabblie-chero__sub">{{ section.settings.subtext }}</p>
    {%- endif -%}

  </div>

  <div class="tabblie-chero__cards-wrap">
    <div class="tabblie-chero__cards">
      {%- for block in section.blocks -%}
        {%- assign col = collections[block.settings.collection] -%}
        {%- assign card_url = block.settings.url | default: col.url | default: '#' -%}
        {%- assign card_label = block.settings.label | default: col.title | default: 'Shop now' -%}

        <a class="tabblie-chero__card" href="{{ card_url }}" {{ block.shopify_attributes }}>
          <div class="tabblie-chero__card-img">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 480 }}"
                alt="{{ card_label | escape }}"
                width="480"
                height="640"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              >
            {%- elsif col.featured_image != blank -%}
              <img
                src="{{ col.featured_image | image_url: width: 480 }}"
                alt="{{ col.title | escape }}"
                width="480"
                height="640"
                loading="lazy"
              >
            {%- else -%}
              {%- assign label_lower = card_label | downcase -%}
              {%- if label_lower contains 'wasstrip' or label_lower contains 'laundry' -%}
                <img src="{{ 'tabblie-wasstrips.png' | asset_url }}" alt="{{ card_label | escape }}" width="480" height="640" loading="lazy">
              {%- elsif label_lower contains 'vaatwas' or label_lower contains 'dishwash' -%}
                <img src="{{ 'tabblie-vaatwasstrips.png' | asset_url }}" alt="{{ card_label | escape }}" width="480" height="640" loading="lazy">
              {%- elsif label_lower contains 'toilet' -%}
                <img src="{{ 'tabblie-toiletstrips.png' | asset_url }}" alt="{{ card_label | escape }}" width="480" height="640" loading="lazy">
              {%- elsif label_lower contains 'alles' or label_lower contains 'all-purpose' -%}
                <img src="{{ 'tabblie-allesreiniger.png' | asset_url }}" alt="{{ card_label | escape }}" width="480" height="640" loading="lazy">
              {%- else -%}
                <div class="tabblie-chero__card-placeholder"></div>
              {%- endif -%}
            {%- endif -%}
          </div>

          <div class="tabblie-chero__card-foot">
            <span class="tabblie-chero__card-label">{{ card_label }}</span>
            <span class="tabblie-chero__card-arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3.75 9H14.25M10.5 5.25L14.25 9L10.5 12.75" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.marquee_text != blank -%}
    {%- assign marquee_items = section.settings.marquee_text | split: '|' -%}
    <div class="tabblie-chero__marquee" aria-hidden="true">
      <div class="tabblie-chero__marquee-track">
        {%- for _i in (1..4) -%}
          {%- for item in marquee_items -%}
            {%- assign item_lower = item | strip | downcase -%}
            <span class="tabblie-chero__marquee-item">
              <svg class="tabblie-chero__marquee-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                {%- if item_lower contains 'plastic' or item_lower contains 'formula' -%}
                  <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2"/><path d="M8 12s1.5-4 4-4 4 4 4 4-1.5 4-4 4-4-4-4-4"/>
                {%- elsif item_lower contains 'ship' or item_lower contains 'nl' -%}
                  <path d="M5 18H3a1 1 0 01-1-1V7a1 1 0 011-1h10v11m0-11h3l4 5v6a1 1 0 01-1 1h-1"/><circle cx="7.5" cy="18.5" r="1.5"/><circle cx="17.5" cy="18.5" r="1.5"/>
                {%- elsif item_lower contains 'vegan' -%}
                  <path d="M2 22c1-6 5.5-12 15-13"/><path d="M17 9c-2 0-6 1-8.5 5.5"/><path d="M22 2L17 9"/>
                {%- elsif item_lower contains 'chemical' or item_lower contains 'harsh' -%}
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>
                {%- elsif item_lower contains 'effective' or item_lower contains 'super' -%}
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                {%- elsif item_lower contains 'money' or item_lower contains 'guarantee' -%}
                  <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                {%- else -%}
                  <circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/>
                {%- endif -%}
              </svg>
              {{ item | strip }}
            </span>
            <span class="tabblie-chero__marquee-dot">·</span>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Collection Hero",
  "tag": "section",
  "class": "tabblie-collection-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Join <strong>thousands</strong> cleaning smarter"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clean home,"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent (italic orange)",
      "default": "smarter for the planet."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "One strip replaces one plastic bottle. No waste, no compromise. Ships to NL & BE."
    },
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee strip (separate items with |)",
      "default": "Plastic-free formula | Ships to NL & BE | 100% vegan | No harsh chemicals | Super effective | Money-back guarantee"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Card label",
          "info": "Leave blank to use collection title"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link",
          "info": "Leave blank to use collection URL"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image",
          "info": "Leave blank to use collection image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Hero",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "label": "Laundry Strips"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "label": "Dishwasher Strips"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "label": "Toilet Strips"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "label": "All-Purpose"
          }
        }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
