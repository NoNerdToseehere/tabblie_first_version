{%- comment -%}
  tabblie-ingredients.liquid
  Ingredient breakdown section — 3-column grid of cream cards.
  Brand: Tabblie — white background, cream cards, orange accent.
{%- endcomment -%}

<style>
  .tabblie-ingredients {
    background-color: #FFFFFF;
    padding: clamp(48px, 6vw, 80px) clamp(16px, 3vw, 40px);
    position: relative;
    overflow: hidden;
  }

  /* Decorative leaves */
  .tabblie-ingredients__leaf {
    position: absolute;
    color: #5BB8A0;
    opacity: 0.15;
    pointer-events: none;
    z-index: 0;
  }

  .tabblie-ingredients__leaf--1 {
    top: 40px;
    left: -40px;
    width: 180px;
    height: 180px;
    transform: rotate(-25deg);
  }

  .tabblie-ingredients__leaf--2 {
    bottom: 60px;
    right: -60px;
    width: 220px;
    height: 220px;
    transform: rotate(140deg);
    color: #E8622A;
    opacity: 0.1;
  }

  .tabblie-ingredients__leaf--3 {
    top: 50%;
    left: 45%;
    width: 90px;
    height: 90px;
    transform: translate(-50%, -50%) rotate(35deg);
    color: #F5C842;
    opacity: 0.08;
  }

  .tabblie-ingredients__inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .tabblie-ingredients__header {
    text-align: center;
    margin-bottom: clamp(32px, 4vw, 56px);
  }

  .tabblie-ingredients__eyebrow {
    font-family: var(--text-font-family);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #E8622A;
    margin: 0 0 12px;
  }

  .tabblie-ingredients__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #1F1209;
    margin: 0;
  }

  .tabblie-ingredients__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 2vw, 24px);
  }

  .tabblie-ingredients__card {
    background-color: #FDF6EE;
    border-radius: 16px;
    padding: clamp(24px, 3vw, 36px);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .tabblie-ingredients__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(31, 18, 9, 0.08);
  }

  .tabblie-ingredients__card-title {
    font-family: var(--font-heading-family);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 600;
    line-height: 1.25;
    color: #1F1209;
    margin: 0 0 12px;
  }

  .tabblie-ingredients__card-desc {
    font-family: var(--text-font-family);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(31, 18, 9, 0.7);
    margin: 0;
  }

  /* Tablet: 2 columns */
  @media (min-width: 750px) and (max-width: 1023px) {
    .tabblie-ingredients__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Mobile: 1 column */
  @media (max-width: 749px) {
    .tabblie-ingredients {
      padding: clamp(36px, 8vw, 56px) 20px;
    }

    .tabblie-ingredients__grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .tabblie-ingredients__card {
      padding: 24px;
    }

    .tabblie-ingredients__card-desc {
      font-size: 14px;
    }

    .tabblie-ingredients__header {
      margin-bottom: 28px;
    }
  }
</style>

<section class="tabblie-ingredients" id="tabblie-ingredients-{{ section.id }}">
  <svg class="tabblie-ingredients__leaf tabblie-ingredients__leaf--1" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <path d="M50 5 C 25 5, 10 30, 10 55 C 10 75, 25 90, 50 95 C 50 70, 35 50, 20 40 C 40 45, 55 60, 50 95 C 75 90, 90 75, 90 55 C 90 30, 75 5, 50 5 Z"/>
  </svg>
  <svg class="tabblie-ingredients__leaf tabblie-ingredients__leaf--2" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <path d="M50 5 C 25 5, 10 30, 10 55 C 10 75, 25 90, 50 95 C 50 70, 35 50, 20 40 C 40 45, 55 60, 50 95 C 75 90, 90 75, 90 55 C 90 30, 75 5, 50 5 Z"/>
  </svg>
  <svg class="tabblie-ingredients__leaf tabblie-ingredients__leaf--3" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <path d="M50 5 C 25 5, 10 30, 10 55 C 10 75, 25 90, 50 95 C 50 70, 35 50, 20 40 C 40 45, 55 60, 50 95 C 75 90, 90 75, 90 55 C 90 30, 75 5, 50 5 Z"/>
  </svg>
  <div class="tabblie-ingredients__inner">

    <div class="tabblie-ingredients__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="tabblie-ingredients__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="tabblie-ingredients__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="tabblie-ingredients__grid">
        {%- for block in section.blocks -%}
          <div class="tabblie-ingredients__card" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="tabblie-ingredients__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="tabblie-ingredients__card-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Ingredient Breakdown",
  "tag": "section",
  "class": "tabblie-ingredients-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow tekst",
      "default": "WAT ZIT ERIN?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "De kracht van elke strip"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Ingredient"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Beschrijving",
          "default": "Beschrijf het ingredi\u00ebnt hier."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Ingredient Breakdown",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "title": "Plantaardige surfactanten",
            "description": "Krachtige, biologisch afbreekbare reinigingsmiddelen op plantbasis. Net zo effectief als chemische alternatieven, maar volledig veilig voor het milieu."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "Natuurlijke enzymen",
            "description": "Breken hardnekkig vuil en vlekken af op natuurlijke wijze. Werken bij lage \u00e9n hoge temperaturen voor een grondige reiniging."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "Essenti\u00eble oli\u00ebn",
            "description": "Een subtiele, frisse geur zonder kunstmatige geurstoffen. Volledig natuurlijk en vrij van allergenen."
          }
        }
      ]
    }
  ]
}
{% endschema %}
