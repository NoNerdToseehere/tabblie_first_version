        "s1": {
          "type": "story",
          "settings": {
            "label": "GEEN PLASTICAFVAL",
            "title": "Eén strip vervangt één plastic fles",
            "body": "<p>Elke wasstrip die je gebruikt is een plastic fles minder in de vuilnisbelt. Onze strips worden verpakt in recyclebaar papier en zijn volledig biologisch afbreekbaar.</p>"
          }
        },
        "s2": {
          "type": "story",
          "settings": {
            "label": "KRACHTIG SCHOON",
            "title": "Dezelfde werkzame stoffen, nul rommel",
            "body": "<p>Plantaardige surfactanten en natuurlijke enzymen zorgen voor een diepe reiniging. Werkt in koud én warm water, op alle stoffen en in elke machine.</p>"
          }
        },
        "s3": {
          "type": "story",
          "settings": {
            "label": "VEILIG VOOR IEDEREEN",
            "title": "Los op in seconden, zonder residu",
            "body": "<p>De strips lossen volledig op in water — geen residu op je kleding, geen chemische vlekken, geen irritatie. Dermatologisch getest en veilig voor baby's, kinderen en gevoelige huid.</p>"
          }
        },
        "s4": {
          "type": "story",
          "settings": {
            "label": "EERLIJKE PRIJS",
            "title": "Beter hoeft niet duurder te zijn",
            "body": "<p>Tabblie kost minder per wasbeurt dan de meeste vloeibare wasmiddelen — en je bespaart op plastic, gewicht en transport. Win-win-win.</p>"
          }
        }
      },
