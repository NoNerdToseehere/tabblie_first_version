    "mea_faq": {
      "type": "tabblie-faq",
      "blocks": {
        "q1": {
          "type": "faq",
          "settings": {
            "question": "Werken de strips echt zo goed als vloeibaar wasmiddel?",
            "answer": "Ja. Onze strips bevatten dezelfde werkzame stoffen als premium wasmiddelen, maar dan in geconcentreerde, vaste vorm. Ze lossen volledig op in koud én warm water."
          }
        },
        "q2": {
          "type": "faq",
          "settings": {
            "question": "Hoeveel wasbeurten zitten er in één pak?",
            "answer": "32 wasbeurten per pak. Eén strip = één was. Voor extra vuile was kun je een halve strip extra gebruiken."
          }
        },
        "q3": {
          "type": "faq",
          "settings": {
            "question": "Zijn de strips veilig voor gevoelige huid en kinderkleding?",
            "answer": "Volledig. Onze formule is dermatologisch getest, hypoallergeen, en vrij van parabenen, fosfaten, kleurstoffen en kunstmatige geurstoffen."
          }
        },
        "q4": {
          "type": "faq",
          "settings": {
            "question": "Werken ze ook op koude wasprogramma's?",
            "answer": "Ja, ze lossen perfect op vanaf 20°C. Scheelt op de energierekening én is beter voor je kleding."
          }
        },
        "q5": {
          "type": "faq",
          "settings": {
            "question": "Wat zit er precies in?",
            "answer": "Plantaardige zepen (kokosolie), biologisch afbreekbare enzymen, plantaardige weekmakers en een lichte, natuurlijke geur. Geen microplastics, geen zooi."
          }
        },
        "q6": {
          "type": "faq",
          "settings": {
            "question": "Geschikt voor alle wasmachines?",
            "answer": "Ja — voorlader, bovenlader, elke combinatie. Stop de strip in de trommel (niet in het zeepbakje) vóór je was."
          }
        },
        "q7": {
          "type": "faq",
          "settings": {
            "question": "Hoe zit het met sterke vlekken?",
            "answer": "Voorbehandel de plek door een stukje strip met wat water tot een pasta te maken, kort laten intrekken, dan gewoon meewassen."
          }
        },
        "q8": {
          "type": "faq",
          "settings": {
            "question": "Hoe bewaar ik de strips?",
            "answer": "Op een droge plek, kamertemperatuur. De papieren verpakking houdt ze maximaal 18 maanden goed."
          }
        },
        "q9": {
          "type": "faq",
          "settings": {
            "question": "Wat als ze niet bevallen?",
            "answer": "Geen probleem. 30 dagen risicovrij. Niet tevreden? Geld volledig terug — geen vragen, geen gedoe."
          }
        },
        "q10": {
          "type": "faq",
          "settings": {
            "question": "Wanneer wordt mijn bestelling geleverd?",
            "answer": "Bestellingen vóór 23:59 worden dezelfde werkdag verstuurd. NL: 1-2 werkdagen, BE: 2-3 werkdagen. Altijd gratis."
          }
        },
        "q11": {
          "type": "faq",
          "settings": {
            "question": "Bieden jullie abonnementen aan?",
            "answer": "Binnenkort. Automatische bezorging met 15% korting, elke 4, 8 of 12 weken. Pauzeren of stoppen kan altijd."
          }
        },
        "q12": {
          "type": "faq",
          "settings": {
            "question": "Wat doen jullie met de winst?",
            "answer": "10% van onze winst gaat naar gecertificeerde milieuprojecten — plastic uit oceanen, herbebossing, en onderzoek naar plastic-alternatieven."
          }
        }
