    "tabblie_founder_main": {
      "type": "tabblie-founder",
      "settings": {
        "eyebrow": "ONS VERHAAL",
        "title": "Een familiebedrijf met een missie",
        "body": "Tabblie begon met een simpel idee: waarom zitten schoonmaakmiddelen nog steeds in plastic flessen? Als familie die houdt van een schoon huis én een schone planeet, wisten we dat het anders kon.\n\nOnze dochter nam het voortouw en ontwikkelde strips die net zo goed werken als traditionele middelen — maar dan zonder plastic, zonder rommel, en zonder schuldgevoel. Elke strip die je gebruikt is een kleine stap richting een schonere wereld. En dat begint gewoon thuis.",
        "button_text": "Meer over tabblie"
      }
    },
    "tabblie_impact_main": {
      "type": "tabblie-impact",
      "settings": {
        "eyebrow": "ONZE BELOFTE",
        "heading": "10% van onze winst gaat naar een groenere planeet",
        "description": "Bij elke bestelling draag je bij aan milieuprojecten. Samen maken we het verschil — strip voor strip.",
        "button_text": "Meer over onze missie"
      }
    },
    "tabblie_faq_main": {
      "type": "tabblie-faq",
      "blocks": {
        "faq_1": {
          "type": "faq",
          "settings": {
            "question": "Zijn jullie strips echt plasticvrij?",
            "answer": "Ja! Onze strips worden verpakt in recyclebaar papier. Geen plastic fles, geen plastic verpakking, geen microplastics in de formule."
          }
        },
        "faq_2": {
          "type": "faq",
          "settings": {
            "question": "Werken de strips net zo goed als vloeibaar wasmiddel?",
            "answer": "Absoluut. Onze strips bevatten dezelfde werkzame stoffen als premium wasmiddelen, maar dan in geconcentreerde vorm. Ze lossen volledig op in warm én koud water."
          }
        },
        "faq_3": {
          "type": "faq",
          "settings": {
            "question": "Zijn de ingrediënten veilig voor gevoelige huid?",
            "answer": "Ja. Onze formule is vrij van parabenen, fosfaten, kleurstoffen en kunstmatige geurstoffen. Dermatologisch getest en geschikt voor de hele familie."
          }
        },
        "faq_4": {
          "type": "faq",
          "settings": {
            "question": "Hoe zit het met de verzending?",
            "answer": "We verzenden gratis naar Nederland en België. Omdat onze strips zo compact en licht zijn, is de CO₂-uitstoot van verzending tot 90% lager dan bij traditionele schoonmaakmiddelen."
          }
        },
        "faq_5": {
          "type": "faq",
          "settings": {
            "question": "Is tabblie vegan en dierproefvrij?",
            "answer": "100%. Geen dierlijke ingrediënten, geen dierproeven. Ooit."
          }
        }
      },
      "block_order": [
        "faq_1",
        "faq_2",
        "faq_3",
        "faq_4",
        "faq_5"
      ],
