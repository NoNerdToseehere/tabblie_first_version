            #halo-image-banner-template--25159110721834__image_banner_4ptiGk .item.item--smallImg .banner-heading, #halo-image-banner-template--25159110721834__image_banner_y97YjF .item.item--smallImg .banner-heading
            ,    .newsletter-section .title {
     
            line-height: 75px !important;
            }

            h3.title .text {
            letter-spacing: -2px;
            }


